# =============================================================================
# Renovation Radar EU — production .env reference
# =============================================================================
# server-setup.sh genereert dit bestand automatisch in /var/www/renovationradar/.env
# Deze versie hier is alleen documentatie — gebruik 'm als reset-template
# wanneer je waarden handmatig moet bijwerken.

# --- Database -----------------------------------------------------------
# Postgres + PostGIS. Wachtwoord = inhoud van .deploy-db-password.
DATABASE_URL="postgresql://renovationradar:CHANGE_ME@localhost:5432/renovationradar?schema=public"

# --- NextAuth -----------------------------------------------------------
# 32+ byte random secret. Genereer: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_32_BYTE_RANDOM"
NEXTAUTH_URL="https://renovationradar.aegiscore.nl"

# --- Redis (BullMQ) -----------------------------------------------------
# Lokale Redis op default-poort. Andere host? Pas aan.
REDIS_URL="redis://localhost:6379"

# --- Meilisearch (fase 4 deel 7+) ---------------------------------------
# Mag leeg blijven tot je een Meilisearch instance draait. De Meilisearch
# client wordt pas geladen wanneer een feature het nodig heeft.
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_MASTER_KEY="not-yet-configured"

# --- Origin (Venlo) -----------------------------------------------------
ORIGIN_LAT="51.3704"
ORIGIN_LNG="6.1724"
ORIGIN_LABEL="Venlo"
MAX_DISTANCE_KM="350"

# --- Search defaults ----------------------------------------------------
MAX_PRICE_EUR="200000"
MIN_LAND_M2="10000"

# --- Next.js runtime ----------------------------------------------------
PORT="3017"             # door server-setup.sh ingevuld op een vrije poort
NODE_ENV="production"

# --- Optioneel: seed dev admin op eerste seed-run -----------------------
# SEED_DEV_ADMIN_EMAIL="jij@example.com"

# --- Optioneel: prod auth-bypass ----------------------------------------
# DEV_AUTH_BYPASS staat default UIT in production. Alleen aanzetten als
# je weet wat je doet (laat de X-Dev-User-Id header werken).
# DEV_AUTH_BYPASS="allow"
