# --- Database -----------------------------------------------------------
DATABASE_URL="postgresql://radar:radar@localhost:5432/renovation_radar?schema=public"

# --- NextAuth -----------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-32-byte-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# --- Redis (BullMQ) -----------------------------------------------------
REDIS_URL="redis://localhost:6379"

# --- Meilisearch --------------------------------------------------------
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_MASTER_KEY="masterKey-change-me"

# --- Origin (Venlo, NL) -------------------------------------------------
# Center of the search radius. Defaults match Venlo.
ORIGIN_LAT="51.3704"
ORIGIN_LNG="6.1724"
ORIGIN_LABEL="Venlo"
MAX_DISTANCE_KM="350"

# --- Search defaults ----------------------------------------------------
MAX_PRICE_EUR="200000"
MIN_LAND_M2="10000"

# --- Geocoding (optional, fill in when phase 2 starts) ------------------
# NOMINATIM_USER_AGENT="renovation-radar/0.1 (contact: you@example.com)"
# MAPBOX_TOKEN=""
