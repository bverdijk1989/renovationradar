{
  "name": "renovation-radar-eu",
  "version": "0.1.0",
  "private": true,
  "description": "Find renovation properties, farmhouses and special objects (mills, station buildings, lock-keeper houses, lighthouses) in FR/BE/DE within 350 km of Venlo.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:postgis": "prisma db execute --file=prisma/sql/postgis_setup.sql --schema=prisma/schema.prisma",
    "db:postgis:tsx": "tsx scripts/apply-postgis.ts",
    "db:push": "prisma db push --skip-generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma db push --skip-generate && pnpm db:postgis && pnpm db:seed",
    "db:reset": "prisma db push --force-reset --skip-generate && pnpm db:postgis && pnpm db:seed",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/api"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slider": "^1.2.2",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.5",
    "bullmq": "^5.34.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ioredis": "^5.4.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "meilisearch": "^0.45.0",
    "next": "^14.2.18",
    "next-auth": "^4.24.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "swr": "^2.2.5",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/leaflet": "^1.9.15",
    "@types/node": "^22.9.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-config-next": "^14.2.18",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.5"
  },
  "packageManager": "pnpm@9.15.4",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "msgpackr-extract",
      "unrs-resolver"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
